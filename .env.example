# ── Ururau v70 — Configuração mínima obrigatória ────────────────────────────
# Copie este arquivo para .env e preencha as variáveis antes de executar.

# OpenAI (obrigatório)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# Fuso horário
TZ_BR=America/Sao_Paulo

# Playwright (opcional — usado no painel CMS)
HEADLESS=false
SLOW_MO=150

# Janelas de deduplicação (horas)
JANELA_ANTIDUPLICACAO_HORAS=48
JANELA_BUSCA_MAXIMA_HORAS=4
JANELA_PRIORIDADE_ULTIMA_HORA=1

# Cache
MAX_ITENS_URURAU_RECENTES=80

# Intervalo monitoramento 24h (segundos)
INTERVALO_ENTRE_CICLOS_SEGUNDOS=1800

# Máximo de publicações por hora no monitoramento
MAX_PUBLICACOES_MONITORAMENTO_POR_HORA=4

# Pastas de saída
PASTA_IMAGENS=imagens
PASTA_PRINTS=prints
PASTA_LOGS=logs
