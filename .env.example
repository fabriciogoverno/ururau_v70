# ── Ururau v70 — Configuração obrigatória ───────────────────────────────────
# Copie este arquivo para .env e preencha TODAS as variáveis antes de executar.
# NUNCA commite o .env real no GitHub.

# ══════════════════════════════════════════════════════════════════════════════
# OPENAI (obrigatório)
# ══════════════════════════════════════════════════════════════════════════════
OPENAI_API_KEY=sk-sua-chave-aqui
OPENAI_MODEL=gpt-4.1-mini

# ══════════════════════════════════════════════════════════════════════════════
# CMS URURAU — Credenciais de login (obrigatório para publicação)
# ══════════════════════════════════════════════════════════════════════════════
URURAU_LOGIN=seu_login_aqui
URURAU_SENHA=sua_senha_aqui
URURAU_ASSINATURA=Fabrício Freitas

SITE_LOGIN_URL=https://www.ururau.com.br/acessocpainel/
SITE_NOVA_URL=https://www.ururau.com.br/acessocpainel/noticias/nova/

# Segurança: apenas SIM permite publicação real no CMS.
# Qualquer outro valor (NAO, 0, false) força modo rascunho.
URURAU_PUBLICACAO_REAL_CONFIRMADA=NAO

# ══════════════════════════════════════════════════════════════════════════════
# PLAYWRIGHT (configuração do browser)
# ══════════════════════════════════════════════════════════════════════════════
HEADLESS=false
SLOW_MO=150

# ══════════════════════════════════════════════════════════════════════════════
# MONITOR 24h — Limites operacionais
# ══════════════════════════════════════════════════════════════════════════════
INTERVALO_ENTRE_CICLOS_SEGUNDOS=1800
MAX_PUBLICACOES_MONITORAMENTO_POR_HORA=4
MAX_PUBLICACOES_POR_CICLO=2
MAX_PUBLICACOES_POR_CANAL=4

# ══════════════════════════════════════════════════════════════════════════════
# JANELAS DE DEDUPLICAÇÃO E BUSCA (horas)
# ══════════════════════════════════════════════════════════════════════════════
JANELA_BUSCA_MAXIMA_HORAS=4
JANELA_PRIORIDADE_ULTIMA_HORA=1
JANELA_ANTIDUPLICACAO_HORAS=48

# ══════════════════════════════════════════════════════════════════════════════
# THRESHOLDS EDITORIAIS
# ══════════════════════════════════════════════════════════════════════════════
LIMIAR_RELEVANCIA_PUBLICAR=65
LIMIAR_RISCO_MAXIMO=15

# ══════════════════════════════════════════════════════════════════════════════
# BANCO DE DADOS E PASTAS
# ══════════════════════════════════════════════════════════════════════════════
ARQUIVO_DB=ururau.db
PASTA_IMAGENS=imagens
PASTA_PRINTS=prints
PASTA_LOGS=logs

# Cache de itens recentes
MAX_ITENS_URURAU_RECENTES=80

# Qualidade das imagens geradas (1-100)
QUALIDADE_JPEG_FINAL=85

# ══════════════════════════════════════════════════════════════════════════════
# FUSO HORÁRIO
# ══════════════════════════════════════════════════════════════════════════════
TZ_BR=America/Sao_Paulo

# ══════════════════════════════════════════════════════════════════════════════
# PESOS EDITORIAIS (opcional — sobrescrevem os defaults)
# ══════════════════════════════════════════════════════════════════════════════
# W_POLITICA_RJ=30
# W_ESTADO_RJ=25
# W_POLICIA=22
# W_ESPORTES=18
# W_SAUDE=14
# W_RURAL=12
# W_BRASIL_MUNDO=10
# W_ECONOMIA=10
# W_CIDADES=10
# SCORE_MIN_AUTOPUBLICACAO=48
# CONFIANCA_MIN_AUTOPUB=70
